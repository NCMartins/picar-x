# PiCar-X Configuration Template
# Generated by Ansible - DO NOT EDIT MANUALLY

# Hardware Configuration
# Motor pins (BCM numbering)
MOTOR_LEFT_FORWARD = {{ picar_motor_left_forward }}
MOTOR_LEFT_BACKWARD = {{ picar_motor_left_backward }}
MOTOR_RIGHT_FORWARD = {{ picar_motor_right_forward }}
MOTOR_RIGHT_BACKWARD = {{ picar_motor_right_backward }}

# PWM Configuration
PWM_FREQUENCY = 1000  # 1 kHz
MAX_SPEED = {{ picar_max_speed }}  # 0-100%

# Servo Configuration (using PCA9685 or similar)
SERVO_PAN_CHANNEL = {{ picar_servo_pan_channel }}
SERVO_TILT_CHANNEL = {{ picar_servo_tilt_channel }}
SERVO_MIN_ANGLE = -90
SERVO_MAX_ANGLE = 90

# Camera Configuration
CAMERA_RESOLUTION = ({{ picar_camera_resolution_width }}, {{ picar_camera_resolution_height }})
CAMERA_FRAMERATE = {{ picar_camera_framerate }}
CAMERA_ROTATION = 0
STREAM_PORT = 8000
STREAM_QUALITY = 80  # 0-100

# Flask Configuration
FLASK_HOST = '{{ picar_flask_host }}'
FLASK_PORT = {{ picar_flask_port }}
FLASK_DEBUG = False

# Streaming Configuration
MJPEG_BOUNDARY = b'--BOUNDARY'
MJPEG_CONTENT_TYPE = 'multipart/x-mixed-replace; boundary=--BOUNDARY'